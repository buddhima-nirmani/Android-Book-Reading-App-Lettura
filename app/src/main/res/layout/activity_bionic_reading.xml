<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".bionicReading"
    android:background="@color/customColor">

    <RelativeLayout
        android:id="@+id/bionicHeader"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="@color/purple">

        <TextView
            android:id="@+id/bionicTitle"
            android:layout_width="116dp"
            android:layout_height="94dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/poppins_bold"
            android:text="BIONIC
            Reader"
            android:textColor="@color/white"
            android:textSize="30sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layoutconverter"
        android:layout_width="match_parent"
        android:layout_height="757dp"
        android:layout_below="@+id/bionicHeader"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginHorizontal="5dp"
            android:layout_marginVertical="25dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <EditText
                android:id="@+id/inputText"
                android:layout_width="373dp"
                android:layout_height="match_parent"
                android:background="@drawable/rounded_edittext"
                android:gravity="top"
                android:hint="Enter your text here"
                android:padding="10dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray" />
        </androidx.cardview.widget.CardView>


        <TextView
            android:id="@+id/wordCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/inputText"
            android:layout_marginLeft="15dp"
            android:layout_marginBottom="5dp"
            android:text="Words: 0/20" />

        <Button
            android:id="@+id/convertButton"
            android:layout_width="255dp"
            android:layout_height="65dp"
            android:layout_below="@id/wordCountText"
            android:layout_marginHorizontal="65dp"
            android:layout_marginVertical="30dp"
            android:backgroundTint="@color/purple"
            android:fontFamily="@font/poppins_bold"
            android:text="Convert"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginHorizontal="5dp"
            android:layout_marginVertical="25dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/bionicTextView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/convertButton"
                android:layout_marginTop="16dp"
                android:background="@drawable/rounded_edittext"
                android:padding="8dp"
                android:hint="Converted Binoic Text"
                android:textColorHint="@color/gray"
                android:textSize="16sp" />
        </androidx.cardview.widget.CardView>


    </LinearLayout>
</RelativeLayout>